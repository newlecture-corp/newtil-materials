{
	"name": "@newtil/materials",
	"version": "0.2.0",
	"description": "Material Design 3 구현 CSS 라이브러리 — m3- prefix 기반 컴포넌트 (버튼, 카드, 다이얼로그, 네비 등). @newtil/design-tokens 위에 동작.",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"style": "./dist/index.css",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./index.css": {
			"default": "./dist/index.css"
		},
		"./package.json": "./package.json"
	},
	"keywords": [
		"css",
		"material design",
		"material 3",
		"m3",
		"ui components",
		"design system"
	],
	"author": "lectureteam",
	"license": "MIT",
	"scripts": {
		"build": "rm -rf ./dist && rollup -c",
		"deploy": "npm run build && npm publish",
		"prepublishOnly": "npm run build",
		"docs:dev": "vitepress dev docs --host",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"dependencies": {
		"@newtil/design-tokens": "^0.1.0"
	},
	"devDependencies": {
		"vitepress": "^1.6.4",
		"@rollup/plugin-terser": "^0.4.4",
		"postcss": "^8.4.33",
		"postcss-import": "^16.1.0",
		"postcss-url": "^10.1.3",
		"rollup": "^4.52.5",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-postcss": "^4.0.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/newlecture-corp/newtil-materials.git"
	},
	"bugs": {
		"url": "https://github.com/newlecture-corp/newtil-materials/issues"
	},
	"homepage": "https://github.com/newlecture-corp/newtil-materials#readme",
	"files": [
		"dist",
		"index.js",
		"index.d.ts",
		"README.md",
		"LICENSE"
	]
}
